@page
@model Web.Pages.Vehiculos.DetalleModel
@{
    ViewData["Title"] = "Detalle del Vehículo";
}

<header class="subhead py-4">
    <div class="container text-center">
        <div class="masthead-subheading">SC-701: Programación Web Avanzada</div>
        <h1 class="masthead-heading text-uppercase mb-0">Detalle del Vehículo</h1>
        <p class="text-muted mb-0">Información completa del registro.</p>
    </div>
</header>

<section class="page-section py-5 bg-light" id="principal">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-9 col-lg-10">

                <div class="card shadow-sm border-0 overflow-hidden">
                    <div class="row g-0">
                        <div class="col-md-4 bg-body-tertiary d-flex align-items-center justify-content-center p-4">
                            <img src="~/assets/img/car.png" class="img-fluid" style="max-height: 180px;" alt="Vehículo">
                        </div>

                        <div class="col-md-8">
                            <div class="card-body p-4 p-md-5">
                                <div class="d-flex align-items-start justify-content-between gap-3">
                                    <div>
                                        <h2 class="h4 mb-1">
                                            @Html.DisplayFor(m => m.vehiculo.Marca) @Html.DisplayFor(m => m.vehiculo.Modelo)
                                        </h2>
                                        <div class="text-muted small">
                                            <i class="bi bi-tag me-1"></i> Placa: @Html.DisplayFor(m => m.vehiculo.Placa)
                                        </div>
                                    </div>

                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle">
                                        @Html.DisplayFor(m => m.vehiculo.Anio)
                                    </span>
                                </div>

                                <hr class="my-4" />

                                <div class="row g-3">
                                    <div class="col-sm-6">
                                        <div class="text-muted small">Precio</div>
                                        <div class="fw-semibold">@Html.DisplayFor(m => m.vehiculo.Precio)</div>
                                    </div>

                                    <div class="col-sm-6">
                                        <div class="text-muted small">Color</div>
                                        <div class="fw-semibold">@Html.DisplayFor(m => m.vehiculo.Color)</div>
                                    </div>

                                    <div class="col-12">
                                        <div class="text-muted small">Contacto</div>
                                        <div class="fw-semibold">
                                            <i class="bi bi-envelope me-1"></i> @Html.DisplayFor(m => m.vehiculo.CorreoPropietario)
                                            <span class="mx-2 text-muted">|</span>
                                            <i class="bi bi-telephone me-1"></i> @Html.DisplayFor(m => m.vehiculo.TelefonoPropietario)
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex gap-2 justify-content-end mt-4">
                                    <a class="btn btn-outline-secondary" asp-page="./Index">Regresar</a>
                                    <a class="btn btn-warning" asp-page="./Editar" asp-route-id="@Model.vehiculo.Id">
                                        <i class="bi bi-pencil-square me-1"></i> Editar
                                    </a>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>