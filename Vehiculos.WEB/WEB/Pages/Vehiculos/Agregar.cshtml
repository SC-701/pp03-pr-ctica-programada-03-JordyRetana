@page
@model Web.Pages.Vehiculos.AgregarModel
@{
    ViewData["Title"] = "Agregar Vehículo";
}

<header class="subhead py-4">
    <div class="container text-center">
        <div class="masthead-subheading">SC-701: Programación Web Avanzada</div>
        <h1 class="masthead-heading text-uppercase mb-0">Agregar Vehículo</h1>
        <p class="text-muted mb-0">Registra un nuevo vehículo en el sistema.</p>
    </div>
</header>

<section class="page-section bg-light py-5" id="principal">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-6 col-lg-7 col-md-9 col-sm-11">

                <div class="card shadow-sm border-0">
                    <div class="card-body p-4 p-md-5">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <h2 class="h4 mb-0">Formulario de registro</h2>
                            <span class="badge bg-success-subtle text-success border border-success-subtle">Nuevo</span>
                        </div>

                        <div class="alert alert-info small mb-4">
                            Completa los campos. Los datos se validan automáticamente antes de guardar.
                        </div>

                        <form method="post" class="needs-validation">
                            <div class="row g-3">

                                <div class="col-12">
                                    <label for="marcas" class="form-label">Marca</label>
                                    <select asp-for="marcaSeleccionada"
                                            class="form-select"
                                            asp-items="Model.marcas"
                                            id="marcas"
                                            onchange="fetchModelos()">
                                        <option value="">Seleccione una marca</option>
                                    </select>
                                </div>

                                <div class="col-12">
                                    <label for="modelos" class="form-label">Modelo <span class="text-danger">*</span></label>
                                    <select asp-for="vehiculo.IdModelo"
                                            class="form-select"
                                            asp-items="Model.modelos"
                                            id="modelos">
                                        <option value="">Seleccione un modelo</option>
                                    </select>
                                    <span class="text-danger small" asp-validation-for="vehiculo.IdModelo"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label" asp-for="vehiculo.Placa"></label>
                                    <input class="form-control"
                                           asp-for="vehiculo.Placa"
                                           id="placa"
                                           maxlength="7"
                                           placeholder="Ej: 123-ABC"
                                           autocomplete="off"
                                           style="text-transform: uppercase;" />
                                    <span class="text-danger small" asp-validation-for="vehiculo.Placa"></span>
                                    <div class="form-text">Formato requerido: <b>###-ABC</b> (ej: <b>123-ABC</b>)</div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label" asp-for="vehiculo.Anio"></label>
                                    <input class="form-control"
                                           asp-for="vehiculo.Anio"
                                           type="number"
                                           min="1900"
                                           max="2100"
                                           placeholder="Ej: 2022" />
                                    <span class="text-danger small" asp-validation-for="vehiculo.Anio"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label" asp-for="vehiculo.Precio"></label>
                                    <div class="input-group">
                                        <span class="input-group-text">₡</span>
                                        <input class="form-control"
                                               asp-for="vehiculo.Precio"
                                               type="number"
                                               step="0.01"
                                               min="0"
                                               placeholder="Ej: 8500000" />
                                    </div>
                                    <span class="text-danger small" asp-validation-for="vehiculo.Precio"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label" asp-for="vehiculo.Color"></label>
                                    <input class="form-control"
                                           asp-for="vehiculo.Color"
                                           placeholder="Ej: Rojo" />
                                    <span class="text-danger small" asp-validation-for="vehiculo.Color"></span>
                                </div>

                                <div class="col-md-7">
                                    <label class="form-label" asp-for="vehiculo.CorreoPropietario"></label>
                                    <input class="form-control"
                                           asp-for="vehiculo.CorreoPropietario"
                                           type="email"
                                           placeholder="correo@dominio.com" />
                                    <span class="text-danger small" asp-validation-for="vehiculo.CorreoPropietario"></span>
                                </div>

                                <div class="col-md-5">
                                    <label class="form-label" asp-for="vehiculo.TelefonoPropietario"></label>
                                    <input class="form-control"
                                           asp-for="vehiculo.TelefonoPropietario"
                                           type="tel"
                                           placeholder="Ej: 8888-8888" />
                                    <span class="text-danger small" asp-validation-for="vehiculo.TelefonoPropietario"></span>
                                </div>

                                <div class="col-12">
                                    <div class="text-danger small" asp-validation-summary="All"></div>
                                </div>

                                <div class="col-12 d-flex gap-2 justify-content-end pt-2">
                                    <a class="btn btn-outline-secondary" asp-page="./Index">Regresar</a>
                                    <button type="submit" class="btn btn-success">
                                        <i class="bi bi-check2-circle me-1"></i> Agregar
                                    </button>
                                </div>

                            </div>
                        </form>
                    </div>
                </div>

                <p class="text-center text-muted small mt-3 mb-0">
                    SC-701 • Módulo Vehículos
                </p>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        async function fetchModelos() {
            const marcaId = document.getElementById('marcas').value;
            const modelosSelect = document.getElementById('modelos');

            if (!marcaId) {
                modelosSelect.innerHTML = '<option value="">Seleccione un modelo</option>';
                return;
            }

            modelosSelect.innerHTML = '<option value="">Cargando modelos...</option>';

            try {
                const response = await fetch(`?handler=ObtenerModelos&marcaId=${marcaId}`);
                if (!response.ok) throw new Error('Error obteniendo los datos');

                const modelos = await response.json();
                modelosSelect.innerHTML = '<option value="">Seleccione un modelo</option>';

                modelos.forEach(modelo => {
                    const option = document.createElement('option');
                    option.value = modelo.id;
                    option.text = modelo.nombre;
                    modelosSelect.appendChild(option);
                });
            } catch (error) {
                console.error('Error obteniendo los datos:', error);
                modelosSelect.innerHTML = '<option value="">No se pudieron cargar</option>';
            }
        }

        (function () {
            const placaInput = document.getElementById("placa");
            if (!placaInput) return;

            placaInput.addEventListener("input", () => {
                let v = (placaInput.value || "").toUpperCase().replace(/[^A-Z0-9]/g, "");

                const nums = v.slice(0, 3).replace(/\D/g, "");
                const letters = v.slice(3, 6).replace(/[^A-Z]/g, "");

                let out = nums;
                if (nums.length === 3) out += "-";
                out += letters;

                placaInput.value = out.slice(0, 7);
            });
        })();
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}